# ============================================================
# MoveShare - Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA subas el archivo .env a git.

# Puerto del servidor (por defecto 3000)
PORT=3000

# Secreto para la sesión (usa una cadena aleatoria larga)
SESSION_SECRET=cambia_esto_por_una_cadena_secreta_larga_y_aleatoria

# ============================================================
# CONFIGURACIÓN DE GMAIL PARA NODEMAILER
# ============================================================
# EMAIL_USER: tu cuenta de Gmail (ej: tuemail@gmail.com)
EMAIL_USER=tuemail@gmail.com

# EMAIL_PASS: NO es tu contraseña normal de Gmail.
# Debes generar una "Contraseña de Aplicación" de Google:
#
# Pasos:
#  1. Ve a: https://myaccount.google.com/security
#  2. Activa la verificación en dos pasos si no está activa.
#  3. Busca "Contraseñas de aplicación" en el buscador de configuración.
#  4. Selecciona aplicación: "Otra (nombre personalizado)" → escribe "MoveShare"
#  5. Google genera un código de 16 caracteres (ej: abcd efgh ijkl mnop)
#  6. Copia ese código SIN espacios y pégalo aquí abajo.
EMAIL_PASS=tucontraseñadeaplicacion
